import json
from pathlib import Path

nb = {
    "cells": [
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "# Constrained Heart PINN for Stiffness Estimation\n",
                "\n",
                "This notebook implements the final publishing-oriented version of the experiment:\n",
                "\n",
                "- fixed `alpha`\n",
                "- fixed forcing amplitude `A`\n",
                "- fixed forcing frequency `f`\n",
                "- learn only the stiffness-like parameter `beta`\n",
                "- enforce realistic bounds on `beta`\n",
                "- use noisy observations of both signal and velocity\n",
                "\n",
                "The goal is to estimate a stiffness-like cardiovascular parameter in a simplified heart-inspired dynamical model."
            ],
        },
        {
            "cell_type": "code",
            "execution_count": None,
            "metadata": {},
            "outputs": [],
            "source": [
                "# ============================================\n",
                "# Final publishing-oriented Heart PINN\n",
                "# ============================================\n",
                "\n",
                "import math\n",
                "import numpy as np\n",
                "import torch\n",
                "import torch.nn as nn\n",
                "import matplotlib.pyplot as plt\n",
                "\n",
                "np.random.seed(42)\n",
                "torch.manual_seed(42)\n",
                "\n",
                "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
                "print(\"Using device:\", device)\n",
                "\n",
                "# --------------------------------------------\n",
                "# True parameters\n",
                "# --------------------------------------------\n",
                "alpha_true = 0.65\n",
                "beta_true = 16.0\n",
                "A_true = 1.6\n",
                "f_true = 1.35\n",
                "\n",
                "x0_true = 0.15\n",
                "v0_true = 0.0\n",
                "\n",
                "# --------------------------------------------\n",
                "# Beta bounds\n",
                "# --------------------------------------------\n",
                "beta_min = 8.0\n",
                "beta_max = 20.0\n",
                "\n",
                "# --------------------------------------------\n",
                "# Data settings\n",
                "# --------------------------------------------\n",
                "t_min_raw, t_max_raw = 0.0, 8.0\n",
                "n_true = 1200\n",
                "n_obs = 300\n",
                "noise_std_x = 0.03\n",
                "noise_std_v = 0.02\n",
                "\n",
                "# --------------------------------------------\n",
                "# RK4 solver\n",
                "# --------------------------------------------\n",
                "def rk4(alpha, beta, A, f, x0, v0, t):\n",
                "    x = np.zeros_like(t)\n",
                "    v = np.zeros_like(t)\n",
                "    x[0], v[0] = x0, v0\n",
                "\n",
                "    def rhs(tt, xx, vv):\n",
                "        return vv, A*np.sin(2*np.pi*f*tt) - alpha*vv - beta*xx\n",
                "\n",
                "    for i in range(len(t) - 1):\n",
                "        h = t[i + 1] - t[i]\n",
                "\n",
                "        k1x, k1v = rhs(t[i], x[i], v[i])\n",
                "        k2x, k2v = rhs(t[i] + h/2, x[i] + h*k1x/2, v[i] + h*k1v/2)\n",
                "        k3x, k3v = rhs(t[i] + h/2, x[i] + h*k2x/2, v[i] + h*k2v/2)\n",
                "        k4x, k4v = rhs(t[i] + h, x[i] + h*k3x, v[i] + h*k3v)\n",
                "\n",
                "        x[i+1] = x[i] + h*(k1x + 2*k2x + 2*k3x + k4x)/6\n",
                "        v[i+1] = v[i] + h*(k1v + 2*k2v + 2*k3v + k4v)/6\n",
                "\n",
                "    return x, v\n",
                "\n",
                "# Generate synthetic data\n",
                "t_raw = np.linspace(t_min_raw, t_max_raw, n_true)\n",
                "x_true, v_true = rk4(alpha_true, beta_true, A_true, f_true, x0_true, v0_true, t_raw)\n",
                "\n",
                "# Normalize time to [0, 1]\n",
                "T_scale = t_max_raw - t_min_raw\n",
                "tau = (t_raw - t_min_raw) / T_scale\n",
                "\n",
                "# Sparse noisy observations\n",
                "idx = np.sort(np.random.choice(n_true, n_obs, replace=False))\n",
                "tau_obs = tau[idx]\n",
                "t_obs_raw = t_raw[idx]\n",
                "\n",
                "x_obs = x_true[idx] + np.random.normal(0, noise_std_x, n_obs)\n",
                "v_obs = v_true[idx] + np.random.normal(0, noise_std_v, n_obs)\n",
                "\n",
                "# --------------------------------------------\n",
                "# Helpers\n",
                "# --------------------------------------------\n",
                "def to_tensor(x, requires_grad=False):\n",
                "    return torch.tensor(x, dtype=torch.float32, device=device).view(-1, 1).requires_grad_(requires_grad)\n",
                "\n",
                "def grad(y, x):\n",
                "    return torch.autograd.grad(\n",
                "        y, x, torch.ones_like(y), create_graph=True, retain_graph=True\n",
                "    )[0]\n",
                "\n",
                "# --------------------------------------------\n",
                "# PINN with bounded beta\n",
                "# --------------------------------------------\n",
                "class PINN(nn.Module):\n",
                "    def __init__(self):\n",
                "        super().__init__()\n",
                "        self.net = nn.Sequential(\n",
                "            nn.Linear(1, 32), nn.Tanh(),\n",
                "            nn.Linear(32, 32), nn.Tanh(),\n",
                "            nn.Linear(32, 32), nn.Tanh(),\n",
                "            nn.Linear(32, 1)\n",
                "        )\n",
                "        self.raw_beta = nn.Parameter(torch.tensor(0.0))\n",
                "        self._init_weights()\n",
                "\n",
                "    def _init_weights(self):\n",
                "        for m in self.modules():\n",
                "            if isinstance(m, nn.Linear):\n",
                "                nn.init.xavier_normal_(m.weight)\n",
                "                nn.init.zeros_(m.bias)\n",
                "\n",
                "    def beta(self):\n",
                "        s = torch.sigmoid(self.raw_beta)\n",
                "        return beta_min + (beta_max - beta_min) * s\n",
                "\n",
                "    def forward(self, tau):\n",
                "        return self.net(tau)\n",
                "\n",
                "# --------------------------------------------\n",
                "# Model and tensors\n",
                "# --------------------------------------------\n",
                "model = PINN().to(device)\n",
                "opt = torch.optim.Adam(model.parameters(), lr=1e-3)\n",
                "\n",
                "tau_obs_t = to_tensor(tau_obs, requires_grad=True)\n",
                "x_obs_t = to_tensor(x_obs)\n",
                "v_obs_t = to_tensor(v_obs)\n",
                "tau_col = to_tensor(np.linspace(0, 1, 1200), requires_grad=True)\n",
                "\n",
                "tau0_t = to_tensor([0.0], requires_grad=True)\n",
                "x0_t = to_tensor([x0_true])\n",
                "v0_t = to_tensor([v0_true])\n",
                "\n",
                "# --------------------------------------------\n",
                "# Training\n",
                "# --------------------------------------------\n",
                "history_beta = []\n",
                "history_loss = []\n",
                "history_loss_x = []\n",
                "history_loss_v = []\n",
                "history_loss_phys = []\n",
                "history_loss_ic = []\n",
                "\n",
                "epochs = 5000\n",
                "\n",
                "for epoch in range(epochs):\n",
                "    opt.zero_grad()\n",
                "\n",
                "    x_pred_obs = model(tau_obs_t)\n",
                "    dx_obs = grad(x_pred_obs, tau_obs_t) / T_scale\n",
                "\n",
                "    loss_x = ((x_pred_obs - x_obs_t) ** 2).mean()\n",
                "    loss_v = ((dx_obs - v_obs_t) ** 2).mean()\n",
                "\n",
                "    x_c = model(tau_col)\n",
                "    dx_c = grad(x_c, tau_col)\n",
                "    ddx_c = grad(dx_c, tau_col)\n",
                "\n",
                "    t_raw_c = t_min_raw + T_scale * tau_col\n",
                "    forcing = A_true * torch.sin(2 * math.pi * f_true * t_raw_c)\n",
                "\n",
                "    res = ddx_c / (T_scale ** 2) + alpha_true * dx_c / T_scale + model.beta() * x_c - forcing\n",
                "    loss_phys = (res ** 2).mean()\n",
                "\n",
                "    x_init = model(tau0_t)\n",
                "    dx_init = grad(x_init, tau0_t) / T_scale\n",
                "    loss_ic = ((x_init - x0_t) ** 2 + (dx_init - v0_t) ** 2).mean()\n",
                "\n",
                "    loss = 10 * loss_x + 10 * loss_v + 10 * loss_phys + 20 * loss_ic\n",
                "    loss.backward()\n",
                "    opt.step()\n",
                "\n",
                "    history_beta.append(model.beta().item())\n",
                "    history_loss.append(loss.item())\n",
                "    history_loss_x.append(loss_x.item())\n",
                "    history_loss_v.append(loss_v.item())\n",
                "    history_loss_phys.append(loss_phys.item())\n",
                "    history_loss_ic.append(loss_ic.item())\n",
                "\n",
                "    if epoch % 500 == 0:\n",
                "        print(f\"{epoch:5d} | beta = {model.beta().item():.6f} | total loss = {loss.item():.6f}\")\n",
                "\n",
                "# --------------------------------------------\n",
                "# Final evaluation\n",
                "# --------------------------------------------\n",
                "beta_learned = model.beta().item()\n",
                "beta_error = abs(beta_learned - beta_true) / beta_true * 100\n",
                "\n",
                "tau_t = to_tensor(tau, requires_grad=True)\n",
                "x_pred_t = model(tau_t)\n",
                "v_pred_t = grad(x_pred_t, tau_t) / T_scale\n",
                "\n",
                "x_pred = x_pred_t.detach().cpu().numpy().flatten()\n",
                "v_pred = v_pred_t.detach().cpu().numpy().flatten()\n",
                "\n",
                "rmse_x = float(np.sqrt(np.mean((x_pred - x_true) ** 2)))\n",
                "rmse_v = float(np.sqrt(np.mean((v_pred - v_true) ** 2)))\n",
                "\n",
                "print(\"\\n========== Final Results ==========\")\n",
                "print(\"True beta:\", beta_true)\n",
                "print(\"Learned beta:\", beta_learned)\n",
                "print(\"Beta error (%):\", beta_error)\n",
                "print(\"RMSE x:\", rmse_x)\n",
                "print(\"RMSE v:\", rmse_v)\n",
                "\n",
                "# --------------------------------------------\n",
                "# Plots\n",
                "# --------------------------------------------\n",
                "plt.figure(figsize=(10, 5))\n",
                "plt.plot(t_raw, x_true, label=\"True signal\")\n",
                "plt.scatter(t_obs_raw, x_obs, s=12, label=\"Noisy x observations\")\n",
                "plt.plot(t_raw, x_pred, label=\"PINN reconstruction\")\n",
                "plt.xlabel(\"Physical time\")\n",
                "plt.ylabel(\"Signal\")\n",
                "plt.title(\"Constrained Heart PINN Reconstruction\")\n",
                "plt.legend()\n",
                "plt.tight_layout()\n",
                "plt.show()\n",
                "\n",
                "plt.figure(figsize=(10, 5))\n",
                "plt.plot(t_raw, v_true, label=\"True velocity\")\n",
                "plt.scatter(t_obs_raw, v_obs, s=12, label=\"Noisy v observations\")\n",
                "plt.plot(t_raw, v_pred, label=\"PINN predicted velocity\")\n",
                "plt.xlabel(\"Physical time\")\n",
                "plt.ylabel(\"Velocity\")\n",
                "plt.title(\"Velocity Reconstruction\")\n",
                "plt.legend()\n",
                "plt.tight_layout()\n",
                "plt.show()\n",
                "\n",
                "plt.figure(figsize=(10, 5))\n",
                "plt.plot(history_beta, label=\"Learned beta\")\n",
                "plt.axhline(beta_true, linestyle=\"--\", label=\"True beta\")\n",
                "plt.xlabel(\"Epoch\")\n",
                "plt.ylabel(\"Beta\")\n",
                "plt.title(\"Beta Convergence\")\n",
                "plt.legend()\n",
                "plt.tight_layout()\n",
                "plt.show()\n",
                "\n",
                "plt.figure(figsize=(10, 5))\n",
                "plt.plot(history_loss, label=\"Total\")\n",
                "plt.plot(history_loss_x, label=\"Data x\")\n",
                "plt.plot(history_loss_v, label=\"Data v\")\n",
                "plt.plot(history_loss_phys, label=\"Physics\")\n",
                "plt.plot(history_loss_ic, label=\"IC\")\n",
                "plt.yscale(\"log\")\n",
                "plt.xlabel(\"Epoch\")\n",
                "plt.ylabel(\"Loss\")\n",
                "plt.title(\"Training Losses\")\n",
                "plt.legend()\n",
                "plt.tight_layout()\n",
                "plt.show()\n",
            ],
        },
    ],
